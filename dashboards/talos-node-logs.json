          },
          "hide": "dontHide",
          "name": "query",
          "query": "",
          "skipUrlSync": false
        }
      },
      {
        "kind": "DatasourceVariable",
        "spec": {
          "allowCustomValue": true,
          "current": {
            "text": "victorialogs",
            "value": "d647dc8a-3cf5-44ba-a287-1da24e409a03"
          },
          "hide": "dontHide",
          "includeAll": false,
          "label": "Logs Datasource",
          "multi": false,
          "name": "DS_LOGS",
          "options": [],
          "pluginId": "victoriametrics-logs-datasource",
          "refresh": "onDashboardLoad",
          "regex": "",
          "skipUrlSync": false
        }
      },
      {
        "kind": "DatasourceVariable",
        "spec": {
          "allowCustomValue": true,
          "current": {
            "text": "VictoriaMetrics",
            "value": "VictoriaMetrics"
          },
          "hide": "dontHide",
          "includeAll": false,
          "label": "Metrics Datasource",
          "multi": false,
          "name": "DS_METRICS",
          "options": [],
          "pluginId": "prometheus",
          "refresh": "onDashboardLoad",
          "regex": "",
