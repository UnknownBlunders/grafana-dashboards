{
  "apiVersion": "dashboard.grafana.app/v2",
  "kind": "Dashboard",
  "metadata": {
    "name": "dcfn5x0snu45q8f"
  },
  "spec": {
    "annotations": [
      {
        "kind": "AnnotationQuery",
        "spec": {
          "builtIn": true,
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations \u0026 Alerts",
          "query": {
            "datasource": {
              "name": "-- Grafana --"
            },
            "group": "grafana",
            "kind": "DataQuery",
            "spec": {},
            "version": "v0"
          }
        }
      }
    ],
    "cursorSync": "Off",
    "description": "Simple dashboard to watch VictoriaLogs\n",
    "editable": true,
    "elements": {
      "panel-1": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "${DS_LOGS}"
                      },
                      "group": "VictoriaLogs",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "expr": "(t_node: ${node} AND filename: ${file}) OR \"${query}\"",
                        "queryType": "range"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "",
          "id": 1,
          "links": [],
          "title": "Logs from ${node} for ${file}",
          "vizConfig": {
            "group": "logs",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {},
                "overrides": []
              },
              "options": {
                "dedupStrategy": "none",
                "enableInfiniteScrolling": false,
                "enableLogDetails": true,
                "prettifyLogMessage": false,
                "showCommonLabels": false,
                "showControls": false,
                "showFieldSelector": false,
                "showLabels": false,
                "showLevel": true,
                "showTime": true,
                "sortOrder": "Descending",
                "timestampResolution": "ms",
                "unwrappedColumns": false,
                "wrapLogMessage": false
              }
            },
            "version": "13.0.1"
          }
        }
      }
    },
    "layout": {
      "kind": "GridLayout",
      "spec": {
        "items": [
          {
            "kind": "GridLayoutItem",
            "spec": {
              "element": {
                "kind": "ElementReference",
                "name": "panel-1"
              },
              "height": 23,
              "width": 24,
              "x": 0,
              "y": 0
            }
          }
        ]
      }
    },
    "links": [
      {
        "asDropdown": false,
        "icon": "external link",
        "includeVars": false,
        "keepTime": false,
        "tags": [],
        "targetBlank": true,
        "title": "Source (GitHub)",
        "tooltip": "View source file in repository",
        "type": "link",
        "url": "https://github.com/UnknownBlunders/grafana-dashboards/blob/main/dashboards/talos-node-logs.json"
      }
    ],
    "liveNow": false,
    "preload": false,
    "tags": [],
    "timeSettings": {
      "autoRefresh": "",
      "autoRefreshIntervals": [
        "5s",
        "10s",
        "30s",
        "1m",
        "5m",
        "15m",
        "30m",
        "1h",
        "2h",
        "1d"
      ],
      "fiscalYearStartMonth": 0,
      "from": "now-6h",
      "hideTimepicker": false,
      "timezone": "browser",
      "to": "now"
    },
    "title": "Node Logs",
    "variables": [
      {
        "kind": "QueryVariable",
        "spec": {
          "allowCustomValue": true,
          "current": {
            "text": "abs",
            "value": "abs"
          },
          "definition": "label_values(kube_namespace_created,namespace)",
          "hide": "dontHide",
          "includeAll": false,
          "multi": false,
          "name": "node",
          "options": [],
          "query": {
            "datasource": {
              "name": "${DS_METRICS}"
            },
            "group": "prometheus",
            "kind": "DataQuery",
            "spec": {
              "qryType": 1,
              "query": "label_values(kube_namespace_created,namespace)",
              "refId": "PrometheusVariableQueryEditor-VariableQuery"
            },
            "version": "v0"
          },
          "refresh": "onDashboardLoad",
          "regex": "",
          "regexApplyTo": "value",
          "skipUrlSync": false,
          "sort": "disabled"
        }
      },
      {
        "kind": "QueryVariable",
        "spec": {
          "allowCustomValue": true,
          "current": {
            "text": "abs-deployment",
            "value": "abs-deployment"
          },
          "definition": "label_values(namespace_workload_pod:kube_pod_owner:relabel{namespace=\"$namespace\"},workload)",
          "hide": "dontHide",
          "includeAll": false,
          "multi": false,
          "name": "file",
          "options": [],
          "query": {
            "datasource": {
              "name": "${DS_METRICS}"
            },
            "group": "prometheus",
            "kind": "DataQuery",
            "spec": {
              "qryType": 1,
              "query": "label_values(namespace_workload_pod:kube_pod_owner:relabel{namespace=\"$namespace\"},workload)",
              "refId": "PrometheusVariableQueryEditor-VariableQuery"
            },
            "version": "v0"
          },
          "refresh": "onDashboardLoad",
